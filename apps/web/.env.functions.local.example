# Optional: required only for local label scan testing.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: used by scan-nutrition server-side PostHog capture.
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=

# Optional: used to hydrate nutrition database contributor names via the Clerk Backend API.
# Without this, contributor display names fall back to 'LeanLog user'.
CLERK_SECRET_KEY=
