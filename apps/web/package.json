{
  "name": "@leanlog/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"pnpm dev:vite\" \"pnpm dev:api\"",
    "build": "tsc -b && vite build",
    "pages:build": "node scripts/migrate.mjs && tsc -b && vite build",
    "lint": "tsc -b --noEmit && eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "dev:vite": "vite --host localhost --port 5173 --strictPort",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:db:migrate": "CI=1 wrangler d1 migrations apply DB --local --persist-to .wrangler/state",
    "dev:db:reset": "wrangler d1 execute DB --local --persist-to .wrangler/state --yes --file scripts/reset-local-d1.sql && pnpm dev:db:migrate",
    "dev:reset": "rm -rf .wrangler/state && pnpm dev:db:migrate"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.14",
    "@clerk/clerk-react": "^5.61.3",
    "@leanlog/data-access": "workspace:*",
    "@leanlog/data-d1": "workspace:*",
    "@leanlog/nutrition-scan": "workspace:*",
    "@leanlog/ui": "workspace:*",
    "ai": "^5.0.100",
    "date-fns": "^4.1.0",
    "jose": "^6.1.3",
    "posthog-js": "^1.386.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.9.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260212.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react-chartjs-2": "^5.3.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.98.0"
  }
}
